# Copy this file to ".env" and fill in your own values.

# The password YOU use to log into /admin.html
ADMIN_PASSWORD=choose-a-strong-password

# A long random string used to keep login sessions secure. Any long random text works.
SESSION_SECRET=change-this-to-a-long-random-string

# Which port the server runs on locally. 3000 is fine.
PORT=3000

# Required — this project stores everything in Supabase.
# Get these from your Supabase project → Settings → API.
SUPABASE_URL=
SUPABASE_SERVICE_KEY=
